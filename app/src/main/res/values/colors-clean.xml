<?xml version="1.0" encoding="utf-8"?>
<!--
    CLEAN UI - Light Theme Colors
    Google Keep inspired: white cards, subtle shadows, clean typography
-->
<resources>
    <!-- Primary brand color - clean indigo (not aggressive blue) -->
    <color name="colorPrimary">#5C6BC0</color>
    <color name="colorPrimaryDark">#3949AB</color>
    <color name="colorPrimaryVariant">#3949AB</color>
    <color name="colorOnPrimary">#FFFFFF</color>

    <!-- Accent / FAB color -->
    <color name="colorAccent">#5C6BC0</color>
    <color name="colorSecondary">#5C6BC0</color>
    <color name="colorOnSecondary">#FFFFFF</color>

    <!-- Backgrounds - pure white like Keep -->
    <color name="colorBackground">#FFFFFF</color>
    <color name="colorSurface">#FFFFFF</color>
    <color name="colorOnBackground">#1C1B1F</color>
    <color name="colorOnSurface">#1C1B1F</color>

    <!-- Note card background -->
    <color name="note_card_background">#FFFFFF</color>
    <color name="note_card_border">#E0E0E0</color>

    <!-- App bar -->
    <color name="appbar_background">#FFFFFF</color>
    <color name="appbar_text">#1C1B1F</color>

    <!-- Text hierarchy -->
    <color name="text_primary">#1C1B1F</color>
    <color name="text_secondary">#49454F</color>
    <color name="text_hint">#938F99</color>

    <!-- Tag chips -->
    <color name="tag_background">#EEF2FF</color>
    <color name="tag_text">#3949AB</color>

    <!-- TODO keyword colors - clean & minimal -->
    <color name="todo_keyword_todo">#E53935</color>
    <color name="todo_keyword_done">#43A047</color>
    <color name="todo_keyword_next">#F57C00</color>
    <color name="todo_keyword_wait">#8E24AA</color>

    <!-- Divider / separator -->
    <color name="divider">#F0F0F0</color>

    <!-- Bottom navigation -->
    <color name="bottom_nav_background">#FFFFFF</color>
    <color name="bottom_nav_selected">#5C6BC0</color>
    <color name="bottom_nav_unselected">#938F99</color>

    <!-- Notebook list item -->
    <color name="notebook_item_background">#FFFFFF</color>
    <color name="notebook_item_background_active">#F5F3FF</color>

    <!-- Error -->
    <color name="colorError">#B3261E</color>
</resources>
